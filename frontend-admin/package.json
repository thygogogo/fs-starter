{
  "name": "fs-starter-admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "run-p type-check \"build-only:prod {@}\" --",
    "build:test": "run-p type-check \"build-only:test {@}\" --",
    "build:prod": "run-p type-check \"build-only:prod {@}\" --",
    "preview": "vp preview",
    "build-only": "vp build --mode production",
    "build-only:test": "vp build --mode test",
    "build-only:prod": "vp build --mode production",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "vp lint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "vp fmt src/",
    "prepare": "vp config"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0",
    "vue": "beta",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plus": "latest",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@vue/compat": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vue": "beta"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
