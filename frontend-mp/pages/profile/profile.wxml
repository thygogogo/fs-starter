<view class="page">
  <view class="user-section">
    <view class="user-header" bindtap="{{isLoggedIn ? '' : 'onLoginTap'}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-info">
        <text class="username">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-id">ID: {{userId || '--'}}</text>
        <text class="register-time">注册: {{registerTime || '--'}}</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view
      class="menu-item"
      wx:for="{{visibleMenuList}}"
      wx:key="id"
      bindtap="onMenuTap"
      data-item="{{item}}"
    >
      <text class="menu-text">{{item.name}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{isLoggedIn}}" class="logout-section" bindtap="onLogoutTap">
    <text class="logout-text">退出登录</text>
  </view>
</view>
