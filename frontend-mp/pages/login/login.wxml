<view class="page">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit" />
    <text class="title">军优享</text>
    <text class="subtitle">登录后享受专属优惠</text>
  </view>

  <button class="login-btn" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">
    微信一键登录
  </button>

  <view class="footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link" bindtap="goAgreement">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link" bindtap="goPrivacy">《隐私政策》</text>
  </view>
</view>
