<view class="page">
  <view class="settings-list">
    <view class="settings-item" bindtap="onAvatarTap">
      <text class="item-label">头像</text>
      <view class="item-value">
        <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="settings-item" bindtap="onNickNameTap">
      <text class="item-label">用户名</text>
      <view class="item-value">
        <text class="item-text">{{nickName || '未设置'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
</view>
