.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.content {
  margin: -40rpx 30rpx 0;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-body {
  margin-bottom: 28rpx;
}

.card-value {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-value.phone {
  color: #ff6b35;
  letter-spacing: 2rpx;
}

.card-value.address {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.6;
}

.card-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.card-tip.official-tip {
  margin-top: 16rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
}

.info-label {
  flex-shrink: 0;
  width: 120rpx;
  font-size: 28rpx;
  color: #999;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.card-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f5f5f5;
}

.card-action.primary {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
}

.card-action.primary .action-text {
  color: #fff;
}

.action-text {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
}

.footer-tip {
  margin: 20rpx 30rpx 0;
  text-align: center;
}

.footer-tip text {
  font-size: 22rpx;
  color: #bbb;
}
