{
  "compileType": "miniprogram",
  "libVersion": "3.16.1",
  "packOptions": {
    "ignore": [
      {
        "value": "miniprogram_npm",
        "type": "folder"
      },
      {
        "value": "*.md",
        "type": "suffix"
      }
    ],
    "include": []
  },
  "setting": {
    "coverView": true,
    "es6": true,
    "postcss": true,
    "minified": true,
    "enhance": true,
    "showShadowRootInWxmlPanel": true,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    },
    "compileWorklet": false,
    "uglifyFileName": false,
    "uploadWithSourceMap": true,
    "packNpmManually": false,
    "minifyWXSS": true,
    "minifyWXML": true,
    "localPlugins": false,
    "condition": false,
    "swc": false,
    "disableSWC": true,
    "disableUseStrict": false,
    "useCompilerPlugins": false,
    "packNpmRelationList": []
  },
  "condition": {},
  "editorSetting": {
    "tabIndent": "auto",
    "tabSize": 2
  },
  "appid": "wxYOUR_APPID_HERE",
  "simulatorPluginLibVersion": {}
}